{
  "name": "cnmooc-downloader",
  "version": "0.2.0",
  "description": "Batch downloader for SJTU CNMOOC (好大学在线) course resources",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "login": "node src/index.js --login-only",
    "list": "node src/index.js --list-only",
    "gui": "node src/server.js",
    "desktop": "electron electron/main.cjs",
    "lint": "node -e \"const fs=require('fs');for(const f of fs.readdirSync('src')){if(f.endsWith('.js'))require('child_process').execSync('node --check src/'+f,{stdio:'inherit'});}require('child_process').execSync('node --check electron/main.cjs',{stdio:'inherit'});const m=fs.readFileSync('public/index.html','utf8').match(/<script>([\\s\\S]*?)<\\/script>/);fs.writeFileSync('.inline.mjs',m[1]);require('child_process').execSync('node --check .inline.mjs',{stdio:'inherit'});fs.unlinkSync('.inline.mjs');console.log('lint ok')\"",
    "prepare:chromium": "node scripts/prepare-build.cjs",
    "build:desktop": "npm run prepare:chromium && electron-builder",
    "build:desktop:win": "npm run prepare:chromium && electron-builder --win",
    "build:desktop:mac": "npm run prepare:chromium && electron-builder --mac",
    "build:desktop:linux": "npm run prepare:chromium && electron-builder --linux"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cli-progress": "^3.12.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "playwright": "^1.48.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  }
}
